<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>A Magical Question for Muskan</title>
    <link href="https://fonts.googleapis.com/css2?family=Pacifico&family=Quicksand:wght@500;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary-pink: #ff4d94;
            --soft-pink: #ff85b3;
            --bg-color: #fff0f6;
        }

        body {
            background-color: var(--bg-color);
            font-family: 'Quicksand', sans-serif;
            margin: 0;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            overflow: hidden;
            transition: background-color 1s ease;
        }

        /* Floating Hearts Background */
        .floating-heart {
            position: absolute;
            color: rgba(255, 77, 148, 0.2);
            font-size: 20px;
            animation: float 6s infinite linear;
            z-index: -1;
        }

        @keyframes float {
            0% { transform: translateY(110vh) rotate(0deg); opacity: 1; }
            100% { transform: translateY(-10vh) rotate(360deg); opacity: 0; }
        }

        .card {
            background: white;
            padding: 40px;
            border-radius: 40px;
            box-shadow: 0 20px 50px rgba(255, 77, 148, 0.2);
            text-align: center;
            border: 8px solid white;
            outline: 4px solid var(--soft-pink);
            max-width: 500px;
            position: relative;
            transform: scale(0.9);
            animation: popIn 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
        }

        @keyframes popIn {
            to { transform: scale(1); }
        }

        .avatar-container {
            width: 180px;
            height: 180px;
            margin: 0 auto 20px;
            border-radius: 50%;
            border: 6px solid var(--primary-pink);
            background: #ffe0ed;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 10px 20px rgba(0,0,0,0.1);
        }

        .avatar-container img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: none; /* Hidden until you add an image link */
        }

        h1 {
            font-family: 'Pacifico', cursive;
            color: var(--primary-pink);
            font-size: 2.5rem;
            margin: 10px 0;
        }

        p {
            font-size: 1.2rem;
            color: #666;
            line-height: 1.5;
        }

        .highlight {
            color: var(--primary-pink);
            font-weight: 700;
        }

        .btn-group {
            margin-top: 30px;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 20px;
            min-height: 100px;
        }

        button {
            border: none;
            padding: 15px 40px;
            font-size: 1.3rem;
            font-weight: 700;
            border-radius: 50px;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            font-family: 'Quicksand', sans-serif;
        }

        #yesBtn {
            background: var(--primary-pink);
            color: white;
            box-shadow: 0 8px 0 #d61a6b;
        }

        #yesBtn:hover {
            transform: scale(1.1) translateY(-5px);
            box-shadow: 0 12px 0 #d61a6b;
        }

        #noBtn {
            background: #eee;
            color: #999;
            z-index: 10;
        }

        /* Success State */
        .hidden { display: none; }

        .celebration-text {
            font-family: 'Pacifico', cursive;
            font-size: 4rem;
            color: white;
            text-shadow: 0 5px 15px rgba(0,0,0,0.2);
            animation: bounce 1s infinite;
        }

        @keyframes bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-20px); }
        }
    </style>
</head>
<body>

    <div class="card" id="proposalCard">
        <div class="avatar-container" id="photoArea">
            <span style="color: var(--soft-pink); font-size: 0.9rem;">Photo Goes Here</span>
        </div>
        
        <h1>Muskan Zulfiqar...</h1>
        <p>My world is more colorful with you in it. <br>
           <span class="highlight">Syed Zulfiqar Mehdi Naqvi</span> has a 
           very important question to ask...</p>
        
        <h2 style="color: var(--primary-pink); font-size: 1.8rem;">Will you marry me?</h2>

        <div class="btn-group">
            <button id="yesBtn" onclick="accept()">YES! 💍</button>
            <button id="noBtn" onmouseover="dodge()" onclick="dodge()">No</button>
        </div>
    </div>

    <div id="successPage" class="hidden" style="text-align: center;">
        <h1 class="celebration-text">SHE SAID YES! 🎉</h1>
        <p style="font-size: 2rem; color: white;">Forever starts now ❤️</p>
    </div>

    <script>
        // Create falling hearts background
        function createHeart() {
            const heart = document.createElement('div');
            heart.classList.add('floating-heart');
            heart.innerHTML = '❤️';
            heart.style.left = Math.random() * 100 + 'vw';
            heart.style.animationDuration = (Math.random() * 3 + 3) + 's';
            document.body.appendChild(heart);
            setTimeout(() => heart.remove(), 6000);
        }
        setInterval(createHeart, 300);

        let yesScale = 1;
        let noClickCount = 0;

        // The No button runs away and makes the Yes button bigger!
        function dodge() {
            const noBtn = document.getElementById('noBtn');
            const yesBtn = document.getElementById('yesBtn');
            
            // Move No button
            const x = Math.random() * (window.innerWidth - 150);
            const y = Math.random() * (window.innerHeight - 100);
            noBtn.style.position = 'absolute';
            noBtn.style.left = x + 'px';
            noBtn.style.top = y + 'px';

            // Grow Yes button dramatically
            yesScale += 0.2;
            yesBtn.style.transform = `scale(${yesScale})`;
            
            // Add funny messages to No button
            const funnyTexts = ["Are you sure?", "Think again!", "Really?", "Pwease?", "You're clicking the wrong one!"];
            noBtn.innerText = funnyTexts[Math.floor(Math.random() * funnyTexts.length)];
        }

        function accept() {
            document.getElementById('proposalCard').classList.add('hidden');
            document.getElementById('successPage').classList.remove('hidden');
            document.body.style.backgroundColor = '#ff4d94';
            
            // Firework effect
            setInterval(() => {
                const firework = document.createElement('div');
                firework.innerHTML = '✨';
                firework.style.position = 'absolute';
                firework.style.left = Math.random() * 100 + 'vw';
                firework.style.top = Math.random() * 100 + 'vh';
                firework.style.fontSize = '2rem';
                firework.style.color = 'white';
                firework.style.animation = 'popOut 0.5s forwards';
                document.body.appendChild(firework);
                setTimeout(() => firework.remove(), 500);
            }, 100);
        }
    </script>
</body>
</html>
